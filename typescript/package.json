{
  "name": "@kairos-connect/sdk",
  "version": "0.3.0",
  "description": "Official TypeScript/JavaScript SDK for Kairos",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "kairos",
    "sdk",
    "tasks",
    "goals",
    "project-management"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moemollaei-org/kairos-connect-sdks.git",
    "directory": "typescript"
  },
  "homepage": "https://thekairos.app/docs/sdks/javascript",
  "bugs": {
    "url": "https://github.com/moemollaei-org/kairos-connect-sdks/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
